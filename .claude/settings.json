{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e 'let s=\"\";process.stdin.on(\"data\",d=>s+=d).on(\"end\",()=>{try{const j=JSON.parse(s);const c=(j.tool_input&&j.tool_input.command)||\"\";if(/git push/.test(c)){const{execSync}=require(\"child_process\");try{execSync(\"node scripts/check-bugs.mjs\",{cwd:process.env.CLAUDE_PROJECT_DIR||\".\",stdio:\"inherit\"})}catch(e){process.exit(2)}}}catch(e){}process.exit(0)})'",
            "timeout": 60,
            "statusMessage": "Vérification des bugs avant déploiement…"
          }
        ]
      }
    ]
  }
}
